# Copy this file to .env and fill in real values

# Postgres connection string (e.g. from a free Neon.tech database).
# Looks like: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=""

# Admin login
ADMIN_EMAIL="admin@srisabari.in"
ADMIN_PASSWORD="ChangeThisPassword123!"

# Secret used to sign admin session cookies (any long random string)
SESSION_SECRET="replace-with-a-long-random-string"

# Public URL of the deployed app (used to build the registration link that
# gets shared with prospective inmates, e.g. https://hostel.srisabari.in)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Email (SMTP) - used for registration confirmation + receipts ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Sri Sabari Ladies Hostel <srisabari.pp@gmail.com>"

# ---- WhatsApp / SMS (Twilio) - optional, used for parent/guardian confirmation ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
TWILIO_SMS_FROM=""
